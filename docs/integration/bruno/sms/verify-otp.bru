meta {
  name: Verify OTP
  type: http
  seq: 2
}

post {
  url: {{BASE_URL}}/v1/sms/otp/verify
  body: json
  auth: bearer
}

auth:bearer {
  token: {{API_KEY}}
}

headers {
  Content-Type: application/json
  x-tenant-id: {{TENANT_ID}}
}

body:json {
  {
    "to": "+919876543210",
    "otp": "847291"
  }
}
